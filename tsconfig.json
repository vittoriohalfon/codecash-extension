{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@codecash/shared": ["./vendor/shared/index.ts"],
      "@codecash/client-core": ["./vendor/client-core/index.ts"],
      "@codecash/client-core/render": ["./vendor/client-core/adapters/claude-cli/render.ts"],
      "@codecash/client-core/daemon-lock": ["./vendor/client-core/lib/daemonControl.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*", "vendor/**/*", "esbuild.mjs"],
  "exclude": ["dist", "node_modules"]
}
